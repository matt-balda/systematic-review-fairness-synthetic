	title = {Enhancing Prediction Accuracy in an Imbalanced Dataset of Dengue Infection Cases Using a Two-layer Ensemble Outlier Detection and Feature Selection Technique},
	year = {2024},
	journal = {International Journal of Intelligent Engineering and Systems},
	volume = {17},
