	author = {Benesch, Danielle and Villatte, Bérangère and Vinet, Alain and Hébert, Sylvie and Voix, Jérémie and Bouserhal, Rachel E.},
	title = {Stress classification with in-ear heartbeat sounds},
	year = {2025},
