@ARTICLE{Qi2026,
	author = {Qi, Yue and Herbault, Lorrie and Lautraite, Hadrien and Yu, Michael and Blanchet, Katleen and Vincelette, Christian and Mullie, Louis and Dumas, Guillaume and Rajotte, Jean-François and Afzali, Kamran and Gambs, Sébastien and Chassé, Michaël},
	title = {CLOVER: A framework for benchmarking synthetic data generation methods balancing utility and privacy in healthcare},
	year = {2026},
