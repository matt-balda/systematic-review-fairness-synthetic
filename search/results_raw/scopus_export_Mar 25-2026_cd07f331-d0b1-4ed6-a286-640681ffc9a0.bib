@ARTICLE{Barbaroux2025,
	author = {Barbaroux, Hugo and Loecher, Michael and Brackenier, Yannick and Kunze, Karl P. and Neji, Radhouene and Pennell, Dudley J. and Ennis, Daniel B. and Nielles-Vallespin, Sonia and Scott, Andrew D. and Young, Alistair A.},
	title = {DENSE-SIM: A modular pipeline for the evaluation of cine displacement encoding with stimulated echoes images with sub-voxel ground-truth strain},
