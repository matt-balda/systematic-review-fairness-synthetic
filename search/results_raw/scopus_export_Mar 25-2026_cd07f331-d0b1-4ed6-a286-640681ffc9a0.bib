	journal = {CEUR Workshop Proceedings},
	volume = {3793},
	pages = {329 - 336},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85208285602&partnerID=40&md5=9db0798a78b12370ab230470943e461d},
	affiliations = {Politecnico di Bari, Via E. Orabona, 4, Bari, 70126, Italy},
	abstract = {Deep learning has revolutionized artificial intelligence by enabling the extraction of intricate representations from large datasets. Generative models have emerged as powerful tools for data synthesis by mimicking the distributions of training data. Despite their advancements, these models encounter critical concerns, including biases, privacy risks, and the authenticity of the generated data. These challenges underscore the necessity for incorporating fairness, expert insights, and comprehensive evaluations into their development. Applications like medical imaging pose challenges due to scarce high-quality data and demanding requirements for condition-specific synthesis. Furthermore, the management of high-dimensional low-sample size (HDLSS) data accentuates the demand for sophisticated representation learning techniques, enabling the generation of effective synthetic data from limited clinical datasets. The complexity of longitudinal medical data, characterized by intricate temporal correlations, further challenges existing methodologies, revealing their limitations. In the light of above, my doctorate research path intends to focus on two main objectives: (i) employ cutting-edge techniques to advance beyond current state-of-the-art in data synthesis, and (ii) bridge the gap between privacy, fairness and generating meaningful synthetic data leveraging on XAI and HCI for further robustness. © 2024 Copyright for this paper by its authors.},
	author_keywords = {Generative Models; HCI; Sensitive Domains; Synthetic Data Augmentation; XAI},
	keywords = {Data assimilation; Differential privacy; Generative adversarial networks; Data augmentation; Data synthesis; Generative model; High-dimensional; Higher-dimensional; Sample sizes; Sensitive domain; Synthetic data; Synthetic data augmentation; XAI; Spatio-temporal data},
	correspondence_address = {D. Danese; Politecnico di Bari, Bari, Via E. Orabona, 4, 70126, Italy; email: danilo.danese@poliba.it},
