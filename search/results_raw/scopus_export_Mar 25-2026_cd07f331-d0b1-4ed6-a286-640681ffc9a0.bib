@CONFERENCE{Chang20246286,
	author = {Chang, Trenton and Wiens, Jenna},
	title = {From Biased Selective Labels to Pseudo-Labels: An Expectation-Maximization Framework for Learning from Biased Decisions},
	year = {2024},
	journal = {Proceedings of Machine Learning Research},
	volume = {235},
	pages = {6286 - 6324},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85203803031&partnerID=40&md5=9756fef0645aaa22fc116bb9c75b79e4},
	affiliations = {Division of Computer Science & Engineering, University of Michigan, Ann Arbor, MI, United States},
	abstract = {Selective labels occur when label observations are subject to a decision-making process; e.g., diagnoses that depend on the administration of laboratory tests. We study a clinically-inspired selective label problem called disparate censorship, where labeling biases vary across subgroups and unlabeled individuals are imputed as “negative” (i.e., no diagnostic test = no illness). Machine learning models naïvely trained on such labels could amplify labeling bias. Inspired by causal models of selective labels, we propose Disparate Censorship Expectation-Maximization (DCEM), an algorithm for learning in the presence of disparate censorship. We theoretically analyze how DCEM mitigates the effects of disparate censorship on model performance. We validate DCEM on synthetic data, showing that it improves bias mitigation (area between ROC curves) without sacrificing discriminative performance (AUC) compared to baselines. We achieve similar results in a sepsis classification task using clinical data. Copyright 2024 by the author(s)},
	keywords = {Adversarial machine learning; Contrastive Learning; Decision making; Causal modeling; Decision-making process; Diagnostic tests; Expectation Maximization; Expectation-Maximization frameworks; Labelings; Laboratory test; Machine learning models; Modeling performance; Synthetic data; Expectation maximization algorithm},
	correspondence_address = {T. Chang; Division of Computer Science & Engineering, University of Michigan, Ann Arbor, United States; email: ctrenton@umich.edu},
