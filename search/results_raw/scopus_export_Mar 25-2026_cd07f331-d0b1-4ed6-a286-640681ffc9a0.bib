@CONFERENCE{Cucos20251139,
	author = {Cucos, Ana Maria and Iantovics, Laszlo Barna},
	title = {Machine Learning-based Adverse Drug Reaction Prediction: Model Comparisons, Feature Optimization and Generative AI Challenges},
	year = {2025},
	journal = {Procedia Computer Science},
	volume = {270},
	pages = {1139 - 1148},
