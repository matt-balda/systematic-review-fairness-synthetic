@CONFERENCE{Szatmary2025673,
	author = {Szatmary, Rozalia and Szatmary, Kornelia Sara and Wang, Fei-Yue},
	title = {Synthetic Data for Infertility Research: A Literature Review},
	year = {2025},
	journal = {CINTI 2025 - IEEE 25th International Symposium on Computational Intelligence and Informatics, Proceedings},
