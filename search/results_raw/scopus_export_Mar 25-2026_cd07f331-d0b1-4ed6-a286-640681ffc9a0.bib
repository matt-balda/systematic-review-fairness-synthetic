	year = {2025},
	journal = {2025 IEEE 15th Annual Computing and Communication Workshop and Conference, CCWC 2025},
	pages = {593 - 598},
	doi = {10.1109/CCWC62904.2025.10903769},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105001121973&doi=10.1109%2FCCWC62904.2025.10903769&partnerID=40&md5=1a1c34bbcb5302c9efc27c276100a169},
	affiliations = {University of Michigan - Flint, Department Of Computing, Flint, MI, United States; University of Nevada - Reno, Department of Biochemistry & Molecular Biology, Reno, NV, United States},
	abstract = {Machine Learning algorithms that deduce insights and extract value from large datasets are increasingly becoming ubiquitous in sleep related healthcare. They are engaged in, and garnish a fair amount of trust and success in patient diagnosis and treatment. Their performance is however dependent on data that may reflect historical societal biases. They may even amplify existing disparities for marginalized groups without malicious intent as they are afforded blind trust in this high impact domain. Learning models built from real data may preserve patterns (knowledge), and address some biases while preserving privacy. Debiased models with comparable accuracy to those built on real data affords opportunities to broadly share and thereby improve precision towards better outcomes. In this paper we explore and assess the generation of synthetic data by generative adversarial networks (GANs) from a practitioner perspective. In this we investigated debiasing and preserving performance in sleep irregularity datasets using different types of GANs, and objectively scrutinize the data synthesis approach using apropos metrics to assess fidelity. We applied CT-GANS to synthesize tabular data with high consistency with a ground truth dataset, however more robust techniques are required for multi-dimentional Polysomnography (PSG) data, a time series approach is required. We consider this as a scientific primer to engage deeper exploration in machine learning applied to sleep. © 2025 IEEE.},
	author_keywords = {deep learning; generative adversarial networks; machine learning; sleep study; synthetic data generation},
	keywords = {Adversarial machine learning; Contrastive Learning; Differential privacy; Federated learning; Adversarial networks; De-biasing; Deep learning; Large datasets; Machine learning algorithms; Machine-learning; Neural-networks; Performance; Sleep studies; Synthetic data generations; Generative adversarial networks},
	correspondence_address = {M. Allison; University of Michigan - Flint, Department Of Computing, Flint, United States; email: markalli@umich.edu; L. Parker; University of Michigan - Flint, Department Of Computing, Flint, United States; email: lacip@umich.edu},
