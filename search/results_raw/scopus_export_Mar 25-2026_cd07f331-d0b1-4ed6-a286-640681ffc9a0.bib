@ARTICLE{Jaspers2024767,
	author = {Jaspers, Tim J.M. and Martens, Bibi and Crawley, Richard and Jada, Lamis and Amirrajab, Sina and Breeuwer, Marcel and Holtackers, Robert J. and Chiribiri, Amedeo and Scannell, Cian M.},
	title = {Deep Learning Synthesis of White-Blood from Dark-Blood Late Gadolinium Enhancement Cardiac Magnetic Resonance},
	year = {2024},
	journal = {Investigative Radiology},
	volume = {59},
	number = {11},
	pages = {767 - 773},
