@CONFERENCE{Chauhan2023133,
	author = {Chauhan, Pavitra and Bongo, Lars Ailo and Pedersen, Edvard},
	title = {Ethical Challenges of Using Synthetic Data},
	year = {2023},
	journal = {Proceedings of the Inaugural 2023 Summer Symposium Series 2023},
	pages = {133 - 134},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85175399428&partnerID=40&md5=2eb826033c86a30da7623e161b01df9d},
	affiliations = {Department of Computer Science, UiT The Arctic University of Norway, Norway},
	abstract = {There is an outburst of digitized medical data with the growing adoption of Electronic Health Record (EHR) systems but have restricted access due to legal compliances. This lack of data accessibility has piqued the interest in generating and using synthetic data. Synthetic data is programmatically generated using the statistical properties of the real dataset. Although synthetic data tackles the issue of legal compliance, there are some ethical concerns associated with it. In this paper, we discuss three ethical concerns of synthetic medical data such as fairness, privacy and unwarranted use. Further, we identify a need to develop a practical framework for statistical evaluation metrics for synthetically generated data. © 2023, Association for the Advancement of Artificial Intelligence (www.aaai.org). All rights reserved.},
