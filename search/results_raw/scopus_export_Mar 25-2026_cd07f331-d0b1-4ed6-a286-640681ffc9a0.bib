@ARTICLE{Haliduola2022863,
	author = {Haliduola, Halimu N. and Bretz, Frank and Mansmann, Ulrich},
	title = {Missing data imputation in clinical trials using recurrent neural network facilitated by clustering and oversampling},
	year = {2022},
	journal = {Biometrical Journal},
	volume = {64},
	number = {5},
	pages = {863 - 882},
	doi = {10.1002/bimj.202000393},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85125993201&doi=10.1002%2Fbimj.202000393&partnerID=40&md5=8f51da31954e6da65753d843534f0bb3},
	affiliations = {Institute for Medical Information Processing, Biometry and Epidemiology (IBE), LMU Munich, Munich, Germany; Alvotech Germany GmbH, Jülich, Germany; Novartis Pharma AG, Basel, Switzerland; Section for Medical Statistics, Medical University of Vienna, Vienna, Austria},
	abstract = {In clinical practice, the composition of missing data may be complex, for example, a mixture of missing at random (MAR) and missing not at random (MNAR) assumptions. Many methods under the assumption of MAR are available. Under the assumption of MNAR, likelihood-based methods require specification of the joint distribution of the data, and the missingness mechanism has been introduced as sensitivity analysis. These classic models heavily rely on the underlying assumption, and, in many realistic scenarios, they can produce unreliable estimates. In this paper, we develop a machine learning based missing data prediction framework with the aim of handling more realistic missing data scenarios. We use an imbalanced learning technique (i.e., oversampling of minority class) to handle the MNAR data. To implement oversampling in longitudinal continuous variable, we first perform clustering via (Formula presented.) -mean trajectories. And use the recurrent neural network (RNN) to model the longitudinal data. Further, we apply bootstrap aggregating to improve the accuracy of prediction and also to consider the uncertainty of a single prediction. We evaluate the proposed method using simulated data. The prediction result is evaluated at the individual patient level and the overall population level. We demonstrate the powerful predictive capability of RNN for longitudinal data and its flexibility for nonlinear modeling. Overall, the proposed method provides an accurate individual prediction for both MAR and MNAR data and reduce the bias of missing data in treatment effect estimation when compared to standard methods and classic models. Finally, we implement the proposed method in a real dataset from an antidepressant clinical trial. In summary, this paper offers an opportunity to encourage the integration of machine learning strategies for handling of missing data in the analysis of randomized clinical trials. © 2022 The Authors. Biometrical Journal published by Wiley-VCH GmbH.},
	author_keywords = {clinical trial; k$k$-mean clustering; missing data; oversampling; recurrent neural network},
	keywords = {Bias; Cluster Analysis; Data Interpretation, Statistical; Humans; Likelihood Functions; Neural Networks, Computer; Data handling; Forecasting; Medical applications; Sensitivity analysis; Classic models; Clinical trial; Clusterings; K$k$-mean clustering; K-means++ clustering; Machine-learning; Missing at randoms; Missing data; Missing not at random; Over sampling; cluster analysis; human; statistical analysis; statistical bias; statistical model; Recurrent neural networks},
	correspondence_address = {U. Mansmann; Institute for Medical Information Processing, Biometry and Epidemiology (IBE), LMU Munich, Munich, Germany; email: mansmann@ibe.med.uni-muenchen.de},
	publisher = {John Wiley and Sons Inc},
	issn = {03233847},
	pmid = {35266565},
	language = {English},
	abbrev_source_title = {Biom. J.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 9; All Open Access; Green Open Access; Hybrid Gold Open Access}
}

