	pages = {},
	doi = {10.1002/nbm.70045},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105003181030&doi=10.1002%2Fnbm.70045&partnerID=40&md5=689c0d557cf05ef3b3bccbdaf1923d43},
	affiliations = {Center for Biomedical Imaging, Department of Radiology, New York University Grossman School of Medicine, New York, NY, United States},
	abstract = {Magnetic resonance fingerprinting (MRF), as an emerging versatile and noninvasive imaging technique, provides simultaneous quantification of multiple quantitative MRI parameters, which have been used to detect changes in cartilage composition and structure in osteoarthritis. Deep learning (DL)–based methods for quantification mapping in MRF overcome the memory constraints and offer faster processing compared to the conventional dictionary matching (DM) method. However, limited attention has been given to the fine-tuning of neural networks (NNs) in DL and fair comparison with DM. In this study, we investigate the impact of training parameter choices on NN performance and compare the fine-tuned NN with DM for multiparametric mapping in MRF. Our approach includes optimizing NN hyperparameters, analyzing the singular value decomposition (SVD) components of MRF data, and optimization of the DM method. We conducted experiments on synthetic data, the NIST/ISMRM MRI system phantom with ground truth, and in vivo knee data from 14 healthy volunteers. The results demonstrate the critical importance of selecting appropriate training parameters, as these significantly affect NN performance. The findings also show that NNs improve the accuracy and robustness of T<sub>1</sub>, T<sub>2</sub>, and T<sub>1ρ</sub> mappings compared to DM in synthetic datasets. For in vivo knee data, the NN achieved comparable results for T<sub>1</sub>, with slightly lower T<sub>2</sub> and slightly higher T<sub>1ρ</sub> measurements compared to DM. In conclusion, the fine-tuned NN can be used to increase accuracy and robustness for multiparametric quantitative mapping from MRF of the knee joint. © 2025 John Wiley & Sons Ltd.},
	author_keywords = {deep learning; MR fingerprinting; musculoskeletal imaging; quantitative MRI},
	keywords = {Adult; Deep Learning; Female; Humans; Knee Joint; Magnetic Resonance Imaging; Male; Neural Networks, Computer; Phantoms, Imaging; Arthroplasty; Brain mapping; Cartilage; Diffusion tensor imaging; Knee prostheses; Nuclear magnetic resonance; Deep learning; Dictionary matching; Fine tuning; Knee joint; Learning models; Matching methods; MR fingerprinting; Musculoskeletal imaging; Neural-networks; Quantitative MRI; adult; Article; book; clinical assessment; comparative study; deep learning; diagnostic accuracy; dictionary matching; female; fine tuning deep learning model; Gaussian noise; human; knee joint; magnetic resonance fingerprinting; male; mathematical parameters; neural network; normal human; nuclear magnetic resonance imaging; osteoarthritis; outcome assessment; process optimization; quantitative analysis; recurrent neural network; singular value decomposition; artificial neural network; diagnostic imaging; imaging phantom; Joints (anatomy)},
