}

@article{attentionaugmentedgenerativead2025,
  author = {K. A; M. Y; N. Kumar S},
  title = {{Attention-Augmented} {Generative} {AdversarialNetworks} {(GANs)} for {Synthetic} {Data} {Augmentationin} {Prostate} {Cancer} {MRI-Bases} {Segmentation} {Tasks}},
  journal = {2025 2nd International Conference on Artificial Intelligence and Knowledge Discovery in Concurrent Engineering (ICECONF)},
  year = {2025},
