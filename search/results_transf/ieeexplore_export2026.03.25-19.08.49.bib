@article{debiasingandpreservingprivacyi2025,
  author = {M. Allison; F. Jefferson; L. Parker; T. Platt; R. Reed; R. Harrison},
  title = {{Debiasing} and {Preserving} {Privacy} in {Sleep} {Datasets} {Using} {Generative} {Adversarial} {Neural} {Networks}},
  journal = {2025 IEEE 15th Annual Computing and Communication Workshop and Conference (CCWC)},
  year = {2025},
  pages = {593--598},
  doi = {10.1109/CCWC62904.2025.10903769},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10903769},
  abstract = {Machine Learning algorithms that deduce insights and extract value from large datasets are increasingly becoming ubiquitous in sleep related healthcare. They are engaged in, and garnish a fair amount of trust and success in patient diagnosis and treatment. Their performance is however dependent on data that may reflect historical societal biases. They may even amplify existing disparities for marginalized groups without malicious intent as they are afforded blind trust in this high impact domain. Learning models built from real data may preserve patterns (knowledge), and address some biases while preserving privacy. Debiased models with comparable accuracy to those built on real data affords opportunities to broadly share and thereby improve precision towards better outcomes. In this paper we explore and assess the generation of synthetic data by generative adversarial networks (GANs) from a practitioner perspective. In this we investigated debiasing and preserving performance in sleep irregularity datasets using different types of GANs, and objectively scrutinize the data synthesis approach using apropos metrics to assess fidelity. We applied CT-GANS to synthesize tabular data with high consistency with a ground truth dataset, however more robust techniques are required for multi-dimentional Polysomnography (PSG) data, a time series approach is required. We consider this as a scientific primer to engage deeper exploration in machine learning applied to sleep.},
  publisher = {IEEE},
  isbn = {979-8-3315-0769-5},
  keywords = {synthetic data generation;generative adversarial networks;sleep study;machine learning;deep learning},
}

@article{evaluatingandreducingsubgroupd2024,
  author = {A. Libin; J. Treitler; T. Vasaitis; Y. Shao},
  title = {{Evaluating} and {Reducing} {Subgroup} {Disparity} in {AI} {Models} {Predicting} {Pediatric} {COVID-19} {Test} {Outcomes}},
  journal = {2024 IEEE International Conference on Big Data (BigData)},
  year = {2024},
  pages = {5033--5042},
  doi = {10.1109/BigData62323.2024.10825572},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10825572},
  abstract = {Artificial Intelligence (AI) fairness in healthcare settings has attracted significant attention due to the concerns to propagate existing health disparities. Despite ongoing research, the frequency and extent of subgroup fairness have not been sufficiently studied. In this study, we extracted a nationally representative pediatric dataset (ages 0-17, n=9,935) from the US National Health Interview Survey (NHIS) concerning COVID-19 test outcomes. For subgroup disparity assessment, we trained 50 models using five machine learning algorithms. We assessed the modelsâ area under the curve (AUC) on 12 small (<15% of the total n) subgroups defined using social economic factors versus the on the overall population. Our results show that subgroup disparities were prevalent (50.7%) in the models. Subgroup AUCs were generally lower, with a mean difference of 0.01, ranging from -0.29 to +0.41. Notably, the disparities were not always statistically significant, with four out of 12 subgroups having statistically significant disparities across models. Additionally, we explored the efficacy of synthetic data in mitigating identified disparities. The introduction of synthetic data enhanced subgroup disparity in 57.7% of the models. The mean AUC disparities for models with synthetic data decreased on average by 0.03 via resampling and 0.04 via generative adversarial network methods.},
  publisher = {IEEE},
  isbn = {979-8-3503-6248-0},
  issn = {2573-2978},
  keywords = {AI fairness;health risk;group parity;machine learning;pediatric population;prediction model;synthetic data},
}

@article{faimrlareinforcementlearningap2025,
  author = {F. Wang; Y. Zhou; Y. Wang; P. Karras; Y. Li},
  title = {{FAIM-RL:} {A} {Reinforcement} {Learning} {Approach} for {Fairness-Aware} {Adaptive} {Influence} {Maximization}},
  journal = {2025 IEEE International Conference on Data Mining (ICDM)},
  year = {2025},
  pages = {783--792},
  doi = {10.1109/ICDM65498.2025.00086},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11392067},
  abstract = {The influence maximization (IM) problem identifies a set $S$ of $k$ seed nodes from a social network $G$ to maximize the expected number of nodes activated through an information diffusion process initiated by $S$. With the broad adoption of IM in sensitive societal domains, including healthcare, education, and recruitment, fairness-aware IM (FIM), which not only maximizes the influence spread but also ensures its proportional distribution between different groups in the population of $G$, has attracted much attention recently. However, existing FIM methods only work under the non-adaptive setting, where all seed nodes must be selected before any influence result is observed. In this paper, we investigate the problem of fairness-aware adaptive IM (FAIM), where the $k$ seed nodes are selected in $B=\lceil k / r\rceil$ batches of equal size $r$, so that the choice of the $b$-th batch can be made after the influence results of the previous $b-1$ batches of seeds have been observed for each $b \in[B]$. We propose FAIM-RL, a new reinforcement learning framework for FAIM. Specifically, by formulating FAIM as a Markov decision process (MDP), the FAIM-RL framework leverages graph neural networks (GNNs) for influence- and topology-based node representations and a deep Q-network (DQN) for expected return estimation, so as to select seed nodes that can strike a balance between maximizing influence spread and ensuring group fairness in each batch. Extensive experiments on four real-world and synthetic network datasets demonstrate that FAIM-RL achieves significantly better trade-offs between influence and fairness metrics than state-of-the-art IM methods. Our code and data are publicly available at https://github.com/fzzf09/FAIM-RL.},
  publisher = {IEEE},
  isbn = {979-8-3315-9599-9},
  issn = {2374-8486},
  keywords = {adaptive influence maximization;deep reinforcement learning;graph neural networks;algorithmic fairness},
}

@article{asurveyonsyntheticdatagenerati2025,
  author = {K.Sathyaseelan; S.Sarathambekai; R.Senthilkumar; S.Gokulraj},
  title = {{A} {Survey} on {Synthetic} {Data} {Generation} for {Diabetes} {Applications}},
  journal = {2025 IEEE 9th International Conference on Information and Communication Technology (CICT)},
  year = {2025},
  pages = {1--12},
  doi = {10.1109/CICT67193.2025.11399110},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11399110},
  abstract = {Synthetic data is increasingly used in diabetes research for solving limited data availability, class imbalance, and patient privacy concerns. This review examines methods for generating synthetic data. It is categorized into four main groups like statistical methods, machine learning approaches, deep learning models and hybrid or emerging frameworks. The use of synthetic data is described across several diabetes related applications. Including electronic health records, continuous glucose monitoring time-series data, medical imaging, decision support systems and data augmentation for predictive modeling. Common real and synthetic datasets were reviewed, highlighting their strengths, weakness and relevance for diabetes studies. The evaluation strategies are reviewed, particularly on data fidelity, model performance and privacy preservation. Several challenges still need to be addressed. This include verifying the reliability of synthetic data and reducing the bias within algorithms. In addition, compliance with regulations like HIPAA and GDPR must be maintained while ensuring the solutions remain practical for real world use. The review highlights several directions for future research. These include advancing generative models and developing personalized with cross domain synthetic data. It also highlights the need for clear ethical and regulatory guidelines to ensure responsible use in clinical settings.},
  publisher = {IEEE},
  isbn = {979-8-3315-7249-5},
  keywords = {Synthetic data generation;Diabetes dataset;Machine and Deep Learning techniques;Class Imbalance},
}

@article{aidrivengenerativemodelingando2025,
  author = {K. Benjilali; A. El-Ibrahimi; W. Moutaouakil; S. Hamida; B. Cherradi; O. Bouattane},
  title = {{AI-Driven} {Generative} {Modeling} and {Optimization} for {Ethical} and {Scalable} {Selection} {Systems:} {A} {Multi-Domain} {Scoping} {Review}},
  journal = {2025 5th International Conference on Innovative Research in Applied Science, Engineering and Technology (IRASET)},
  year = {2025},
  pages = {1--8},
  doi = {10.1109/IRASET64571.2025.11008162},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11008162},
  abstract = {Generative Artificial Intelligence (GAI) transforms selection and recommendation systems by enabling automated optimization, enhanced personalization, and intelligent decision-making. This scoping review surveys the integration of GAI-driven selection models across domains, such as recruitment, healthcare, education, and e-commerce, demonstrating improvements in accuracy, efficiency, and scalability. AI-enhanced personal selection, healthcare decision support systems, and generative adversarial networks (GANs) for personalized selection illustrate the impact of synthetic data generation and deep learning on optimizing user experience. Despite these advancements, ethical concerns, including algorithmic bias, transparency, and data privacy, remain important challenges. By consolidating state-of-the-art approaches and methodologies, this review maps key advancements, identifies research gaps, and proposes future directions to ensure responsible and scalable deployment of Generative AI in selection and recommendation systems.},
  publisher = {IEEE},
  isbn = {979-8-3315-3297-0},
  keywords = {Generative Artificial Intelligence;GAI;Recommendation Systems;Automated Optimization;Selection Systems;generative adversarial networks;GANs;Recruitment;Healthcare;Education;Ethical AI;Algorithmic bias},
}

@article{modelbasedconvolutionneuralnet2025,
  author = {C. Wei; Z. Li; T. Hu; M. Zhao; Z. Sun; K. Jia; J. Feng; B. W. Pogue; K. D. Paulsen; S. Jiang},
  title = {{Model-Based} {Convolution} {Neural} {Network} for {3D} {Near-Infrared} {Spectral} {Tomography}},
  journal = {IEEE Transactions on Medical Imaging},
  year = {2025},
  volume = {44},
  number = {5},
  pages = {2330--2340},
  doi = {10.1109/TMI.2025.3529621},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10841441},
  abstract = {Near-infrared spectral tomography (NIRST) is a non-invasive imaging technique that provides functional information about biological tissues. Due to diffuse light propagation in tissue and limited boundary measurements, NIRST image reconstruction presents an ill-posed and ill-conditioned computational problem that is difficult to solve. To address this challenge, we developed a reconstruction algorithm (Model-CNN) that integrates a diffusion equation model with a convolutional neural network (CNN). The CNN learns a regularization prior to restrict solutions to the space of desirable chromophore concentration images. Efficacy of Model-CNN was evaluated by training on numerical simulation data, and then applying the network to physical phantom and clinical patient NIRST data. Results demonstrated the superiority of Model-CNN over the conventional Tikhonov regularization approach and a deep learning algorithm (FC-CNN) in terms of absolute bias error (ABE) and peak signal-to-noise ratio (PSNR). Specifically, in comparison to Tikhonov regularization, Model-CNN reduced average ABE by 55% for total hemoglobin (HbT) and 70% water (H $_\{\mathbf \{\{2\}\}\}$  O) concentration, while improved PSNR by an average of 5.3 dB both for HbT and H $_\{\mathbf \{\{2\}\}\}$  O images. Meanwhile, image processing time was reduced by 82%, relative to the Tikhonov regularization. As compared to FC-CNN, the Model-CNN achieved a 91% reduction in ABE for HbT and 75% for H $_\{\mathbf \{\{2\}\}\}$  O images, with increases in PSNR by 7.3 dB and 4.7 dB, respectively. Notably, this Model-CNN approach was not trained on patient data; but instead, was trained on simulated phantom data with simpler geometrical shapes and optical source-detector configurations; yet, achieved superior image recovery when faced with real-world data.},
  publisher = {IEEE},
  issn = {1558-254X},
  keywords = {Near-infrared spectral tomography;image reconstruction;deep learning;convolutional neural network},
}

@article{generativeaienhanceddeeplearni2025,
  author = {D. D; R. Pugalenthi},
  title = {{Generative} {AI-Enhanced} {Deep} {Learning} for {Glaucoma:} {A} {Framework} for {Early} {Detection} and {Progression} {Forecasting}},
  journal = {2025 5th International Conference on Evolutionary Computing and Mobile Sustainable Networks (ICECMSN)},
  year = {2025},
  pages = {94--98},
  doi = {10.1109/ICECMSN68058.2025.11382756},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11382756},
  abstract = {Glaucoma is still a leading cause of permanent blindness, and artificial intelligence (AI) has the potential to be used to detect the disease at an early stage. Nevertheless, the current constraints of ophthalmic datasets in the development of deep learning (DL) models are devastating because they are small, unheterogeneous, and cross-sectional in nature. To address these data-centric bottlenecks, this paper suggests a new framework to be implemented with the help of generative AI. We present a procedure by which large-scale, high-fidelity syn- thetic data of color fundus photographs and optical coherence tomography (OCT) scans might be produced using Generative Adversarial Networks (GANs). This is not only a way of overcoming data scarcity and bias in representation, but also allows the synthesis of longitudinal data to model the progression of a disease. Such enhanced datasets will be trained on the models of advanced DLs: a Vision Transformer (ViT) to detect the early signs and a spatiotemporal Convolutional Long Short-Term Memory (ConvLSTM) network to predict the progression. Such models should perform much better than models trained using real data alone especially with respect to their extrapolation to a wide range of real-world clinical environments. This framework will generate credible, precise, and fair AI tools by incorporating explainable AI (XAI) methods, which will lead to customized and predictive glaucoma care.},
  publisher = {IEEE},
  isbn = {979-8-3315-8242-5},
  keywords = {Glaucoma;Generative AI;Deep Learning;Synthetic Data;GAN;Vision Transformer;Progression Prediction;Explainable AI;Ophthalmic Imaging;Data Augmentation},
}

@article{syntheticdataforassessingrobus2025,
  author = {R. V; R. Sathish; M. Pattanaik; K. A. R. Babu},
  title = {{Synthetic} {Data} for {Assessing} {Robustness} of {Deep} {Learning} {Models} to {Distributional} {Shifts}},
  journal = {2025 IEEE 22nd International Symposium on Biomedical Imaging (ISBI)},
  year = {2025},
  pages = {1--4},
  doi = {10.1109/ISBI60581.2025.10980769},
