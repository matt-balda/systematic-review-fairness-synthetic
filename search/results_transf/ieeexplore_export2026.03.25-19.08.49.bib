  abstract = {The availability of high-quality datasets is essential for advancing artificial intelligence, yet sensitive domains such as healthcare, finance, crime investigation, and legal systems face acute data scarcity due to privacy regulations and ethical constraints. Synthetic data, generated to preserve the statistical properties of real datasets while mitigating disclosure risks, has emerged as a viable solution to these challenges. This paper reviews state-of-the-art generation methodsâincluding generative adversarial networks (GANs), variational autoencoders (VAEs), diffusion models, and transformer-based approachesâalongside applications in high-stakes sectors, comparisons with traditional anonymization, and the role of hybrid and privacy-preserving synthesis. We further analyze key challenges such as the realismâprivacy trade-off, evaluation gaps, bias amplification, and regulatory uncertainty, while outlining future directions in domain-specific pipelines, governance frameworks, and synthetic data marketplaces. Our findings highlight synthetic data as a cornerstone for ethical, reproducible, and scalable AI deployment in sensitive and data-restricted environments.},
  publisher = {IEEE},
  isbn = {979-8-3315-6505-3},
  keywords = {Synthetic Data;Generative Adversarial Networks (GANs);Variational Autoencoders (VAEs);Diffusion Models},
}

@article{advancedmethodsforaddressingim2025,
  author = {M. Rout; K. Batra; S. Mittal},
  title = {{Advanced} {Methods} for {Addressing} {Imbalanced} {Datasets} in {Bone} {Fracture} {Detection}},
  journal = {2025 International Conference on Advancements in Smart, Secure and Intelligent Computing (ASSIC)},
  year = {2025},
  pages = {1--5},
  doi = {10.1109/ASSIC64892.2025.11158528},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11158528},
  abstract = {Managing imbalanced datasets remains a key problem in machine learning, especially in areas such as healthcare, fraud detection, and industrial applications. Traditional methods such as random oversampling, undersampling, and data augmentation often fail to effectively balance datasets, often introducing redundancy and noise. These shortcomings result in models that are biased and generalize poorly. In this article, we present a dual-strategy approach that is tailored to the degree of class imbalance. For datasets with mild imbalance, the proposed method involves DOWNSAMPLING and UPWEIGHTING the majority class, ensuring a simpler yet effective solution. For extreme imbalance, a more robust combination of Adaptive Synthetic sampling (ADASYN) and Neighborhood Cleaning Rule (NCL) is used. ADASYN generates synthetic samples of the minority class, while NCL removes noisy samples from the majority class, thus improving the quality of the dataset. The proposed method is evaluated on a fracture dataset that exhibits severe class imbalance, with intact bone data accounting for only 5% of the total data. Results show substantial improvements across multiple metrics, including Recall, F1 Score and the AUC Curve. These findings demonstrate the efficacy of the proposed approach in addressing both mild and extreme class imbalance.},
  publisher = {IEEE},
  isbn = {979-8-3315-2302-2},
  keywords = {Adaptive Synthetic Sampling (ADASYN);Neighborhood Cleaning Rule (NCL);downsampling;upweighting;synthetic data generation;machine learning;classification;fractured bone dataset},
}

@article{classndiffclassificationinduce2025,
